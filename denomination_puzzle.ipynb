    "import pygame\n",
    "import sys\n",
    "import threading\n",
    "import time\n",
    "import colorsys\n",
    "\n",
    "# --- Background Solver Thread ---\n",
    "class SolverThread(threading.Thread):\n",
    "    def __init__(self, rows, cols):\n",
    "        super().__init__()\n",
    "        self.rows = rows\n",
    "        self.cols = cols\n",
    "        self.best_max = 0\n",
    "        self.running = True\n",
    "        self.searching = True\n",
    "        self.daemon = True\n",
    "\n",
    "    def run(self):\n",
    "        memo = set()\n",
    "        stack = []\n",
    "        \n",
    "        # Add initial states (Null stone placement)\n",
    "        # Symmetry reduction: Only consider the top-left quadrant for the very first stone\n",
    "        for r in range((self.rows + 1) // 2):\n",
    "            for c in range((self.cols + 1) // 2):\n",
    "                idx = r * self.cols + c\n",
    "                board = [0] * (self.rows * self.cols)\n",
    "                board[idx] = -1  # -1 signifies the Null stone\n",
    "                stack.append((tuple(board), 1))\n",
    "\n",
    "        # Precompute neighbors for 1D array to speed up the DFS\n",
    "        neighbors = []\n",
    "        for i in range(self.rows * self.cols):\n",
    "            r, c = divmod(i, self.cols)\n",
    "            n_list = []\n",
    "            for dr in [-1, 0, 1]:\n",
    "                for dc in [-1, 0, 1]:\n",
    "                    if dr == 0 and dc == 0: continue\n",
    "                    nr, nc = r + dr, c + dc\n",
    "                    if 0 <= nr < self.rows and 0 <= nc < self.cols:\n",
    "                        n_list.append(nr * self.cols + nc)\n",
    "            neighbors.append(n_list)\n",
    "\n",
    "        start_time = time.time()\n",
    "        \n",
    "        while stack and self.running:\n",
    "            # Prevent the solver from running forever on large grids (8 sec limit)\n",
    "            if time.time() - start_time > 8.0:\n",
    "                break\n",
    "\n",
    "            board, k = stack.pop()\n",
    "\n",
    "            if k > self.best_max:\n",
    "                self.best_max = k\n",
    "\n",
    "            # Find valid moves\n",
    "            for i in range(self.rows * self.cols):\n",
    "                if board[i] == 0:\n",
    "                    s = 0\n",
    "                    for n in neighbors[i]:\n",
    "                        s += abs(board[n]) # abs() handles the -1 Null stone properly\n",
    "\n",
    "                    if 0 < s <= k + 1:\n",
    "                        new_board = list(board)\n",
    "                        new_board[i] = s\n",
    "                        new_k = s if s > k else k\n",
    "                        new_tuple = tuple(new_board)\n",
    "\n",
    "                        if new_tuple not in memo:\n",
    "                            memo.add(new_tuple)\n",
    "                            stack.append((new_tuple, new_k))\n",
    "                            \n",
    "        self.searching = False\n",
    "\n",
    "# --- UI Components ---\n",
    "class Button:\n",
    "    def __init__(self, x, y, w, h, text, callback, color=(52, 152, 219), hover_color=(41, 128, 185)):\n",
    "        self.rect = pygame.Rect(x, y, w, h)\n",
    "        self.text = text\n",
    "        self.callback = callback\n",
    "        self.color = color\n",
    "        self.hover_color = hover_color\n",
    "\n",
    "    def draw(self, surface, font):\n",
    "        mouse_pos = pygame.mouse.get_pos()\n",
    "        color = self.hover_color if self.rect.collidepoint(mouse_pos) else self.color\n",
    "        pygame.draw.rect(surface, color, self.rect, border_radius=8)\n",
    "        \n",
    "        # Button text\n",
    "        text_surf = font.render(self.text, True, (255, 255, 255))\n",
    "        text_rect = text_surf.get_rect(center=self.rect.center)\n",
    "        surface.blit(text_surf, text_rect)\n",
    "\n",
    "    def handle_event(self, event):\n",
    "        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:\n",
    "            if self.rect.collidepoint(event.pos):\n",
    "                self.callback()\n",
    "\n",
    "class TextBox:\n",
    "    def __init__(self, x, y, w, h, text='4'):\n",
    "        self.rect = pygame.Rect(x, y, w, h)\n",
    "        self.color_inactive = (127, 140, 141)\n",
    "        self.color_active = (52, 152, 219)\n",
    "        self.color = self.color_inactive\n",
    "        self.text = text\n",
    "        self.active = False\n",
    "        self.font = pygame.font.SysFont('segoeui', 32, bold=True)\n",
    "\n",
    "    def handle_event(self, event):\n",
    "        if event.type == pygame.MOUSEBUTTONDOWN:\n",
    "            self.active = self.rect.collidepoint(event.pos)\n",
    "            self.color = self.color_active if self.active else self.color_inactive\n",
    "        if event.type == pygame.KEYDOWN and self.active:\n",
    "            if event.key == pygame.K_BACKSPACE:\n",
    "                self.text = self.text[:-1]\n",
    "            elif event.unicode.isdigit() and len(self.text) < 2:\n",
    "                self.text += event.unicode\n",
    "\n",
    "    def draw(self, surface):\n",
    "        # Fill background\n",
    "        pygame.draw.rect(surface, (44, 62, 80), self.rect, border_radius=6)\n",
    "        # Draw border\n",
    "        pygame.draw.rect(surface, self.color, self.rect, 3, border_radius=6)\n",
    "        # Draw text\n",
    "        txt_surface = self.font.render(self.text, True, (236, 240, 241))\n",
    "        txt_rect = txt_surface.get_rect(center=self.rect.center)\n",
    "        surface.blit(txt_surface, txt_rect)\n",
    "\n",
    "    def get_value(self):\n",
    "        return int(self.text) if self.text.isdigit() and int(self.text) > 0 else 3 # Default to 3 if invalid\n",
    "\n",
    "\n",
    "# --- Main Game Class ---\n",
    "class DenominationGame:\n",
    "    def __init__(self):\n",
    "        pygame.init()\n",
    "        self.WIDTH, self.HEIGHT = 800, 800\n",
    "        self.screen = pygame.display.set_mode((self.WIDTH, self.HEIGHT))\n",
    "        pygame.display.set_caption(\"Denomination Puzzle\")\n",
    "        self.clock = pygame.time.Clock()\n",
    "\n",
    "        # Fonts\n",
    "        self.title_font = pygame.font.SysFont('segoeui', 56, bold=True)\n",
    "        self.subtitle_font = pygame.font.SysFont('segoeui', 32)\n",
    "        self.info_font = pygame.font.SysFont('segoeui', 24)\n",
    "        self.stone_font = pygame.font.SysFont('segoeui', 36, bold=True)\n",
    "        self.btn_font = pygame.font.SysFont('segoeui', 20, bold=True)\n",
    "\n",
    "        # Game State\n",
    "        self.app_state = \"MENU\" # MENU, GAME\n",
    "        self.rows = 4\n",
    "        self.cols = 4\n",
    "        self.solver_thread = None\n",
    "        self.valid_moves = {}\n",
    "\n",
    "        # Menu Inputs\n",
    "        self.row_input = TextBox(430, 300, 80, 50, '4')\n",
    "        self.col_input = TextBox(430, 380, 80, 50, '4')\n",
    "        \n",
    "        # Buttons\n",
    "        self.menu_buttons = [\n",
    "            Button(300, 480, 200, 60, \"START GAME\", self.start_game, color=(46, 204, 113), hover_color=(39, 174, 96)),\n",
    "            Button(300, 560, 200, 60, \"EXIT GAME\", self.exit_game, color=(231, 76, 60), hover_color=(192, 57, 43))\n",
    "        ]\n",
    "        self.game_buttons = [\n",
    "            Button(200, 720, 150, 50, \"Restart\", lambda: self.reset(self.rows, self.cols), color=(231, 76, 60), hover_color=(192, 57, 43)),\n",
    "            Button(450, 720, 150, 50, \"Back to Menu\", self.go_to_menu, color=(149, 165, 166), hover_color=(127, 140, 141))\n",
    "        ]\n",
    "\n",
    "    def go_to_menu(self):\n",
    "        self.app_state = \"MENU\"\n",
    "        if self.solver_thread and self.solver_thread.is_alive():\n",
    "            self.solver_thread.running = False\n",
    "            self.solver_thread.join(timeout=0.1)\n",
    "\n",
    "    def exit_game(self):\n",
    "        if self.solver_thread:\n",
    "            self.solver_thread.running = False\n",
    "        pygame.quit()\n",
    "        sys.exit()\n",
    "\n",
    "    def start_game(self):\n",
    "        # Cap grid size to 15x15 visually to avoid absurd inputs crashing display\n",
    "        r = min(15, self.row_input.get_value())\n",
    "        c = min(15, self.col_input.get_value())\n",
    "        self.reset(r, c)\n",
    "        self.app_state = \"GAME\"\n",
    "\n",
    "    def reset(self, rows, cols):\n",
    "        self.rows = rows\n",
    "        self.cols = cols\n",
    "        # board stores -1 for Null, 0 for empty, >0 for normal stones\n",
    "        self.board = [[0 for _ in range(cols)] for _ in range(rows)]\n",
    "        self.max_k = 0\n",
    "        self.game_state = \"WAITING_FOR_NULL\" # WAITING_FOR_NULL, PLAYING, GAME_OVER\n",
    "        \n",
    "        # Stop existing solver thread\n",
    "        if self.solver_thread and self.solver_thread.is_alive():\n",
    "            self.solver_thread.running = False\n",
    "            self.solver_thread.join(timeout=0.1)\n",
    "            \n",
    "        # Start new solver thread\n",
    "        self.solver_thread = SolverThread(rows, cols)\n",
    "        self.solver_thread.start()\n",
    "\n",
    "        self.valid_moves = self.get_valid_moves()\n",
    "\n",
    "    def get_valid_moves(self):\n",
    "        moves = {}\n",
    "        if self.game_state == \"WAITING_FOR_NULL\":\n",
    "            for r in range(self.rows):\n",
    "                for c in range(self.cols):\n",
    "                    moves[(r, c)] = 1\n",
    "            return moves\n",
    "\n",
    "        for r in range(self.rows):\n",
    "            for c in range(self.cols):\n",
    "                if self.board[r][c] == 0:\n",
    "                    s = 0\n",
    "                    for dr in [-1, 0, 1]:\n",
    "                        for dc in [-1, 0, 1]:\n",
    "                            if dr == 0 and dc == 0: continue\n",
    "                            nr, nc = r + dr, c + dc\n",
    "                            if 0 <= nr < self.rows and 0 <= nc < self.cols:\n",
    "                                s += abs(self.board[nr][nc])\n",
    "                    \n",
    "                    # Core Rule: Neighbour sum must be <= max_k + 1\n",
    "                    if 0 < s <= self.max_k + 1:\n",
    "                        moves[(r, c)] = s\n",
    "        return moves\n",
    "\n",
    "    def get_stone_color(self, value):\n",
    "        if value == -1:\n",
    "            return (30, 30, 30) # Shiny normal black stone for Null\n",
    "        # Programmatically assign colors based on number value\n",
    "        hue = (value * 0.12) % 1.0\n",
    "        r, g, b = colorsys.hsv_to_rgb(hue, 0.8, 0.85)\n",
    "        return (int(r*255), int(g*255), int(b*255))\n",
    "\n",
    "    def draw_polished_stone(self, surface, center, radius, base_color, val_text, alpha=255):\n",
    "        x, y = center\n",
    "        surf_size = radius * 2 + 10\n",
    "        stone_surf = pygame.Surface((surf_size, surf_size), pygame.SRCALPHA)\n",
    "        cx, cy = surf_size // 2, surf_size // 2\n",
    "        \n",
    "        # 1. Drop Shadow\n",
    "        pygame.draw.circle(stone_surf, (0, 0, 0, min(140, alpha)), (cx + 3, cy + 4), radius)\n",
    "        \n",
    "        # 2. Base Colored Stone\n",
    "        pygame.draw.circle(stone_surf, (*base_color, alpha), (cx, cy), radius)\n",
    "        \n",
    "        # 3. Inner darker rim for 3D depth\n",
    "        rim_color = (max(0, base_color[0]-50), max(0, base_color[1]-50), max(0, base_color[2]-50), alpha)\n",
    "        pygame.draw.circle(stone_surf, rim_color, (cx, cy), radius, max(1, radius//10))\n",
    "        \n",
    "        # 4. Specular Highlight (The 'Polish')\n",
    "        hl_w, hl_h = radius * 0.8, radius * 0.4\n",
    "        pygame.draw.ellipse(stone_surf, (255, 255, 255, min(100, alpha)), \n",
    "                            (cx - hl_w//2, cy - radius*0.7, hl_w, hl_h))\n",
    "        \n",
    "        # 5. Text Render\n",
    "        txt = self.stone_font.render(val_text, True, (255, 255, 255))\n",
    "        if alpha < 255:\n",
    "            txt.set_alpha(alpha)\n",
    "        txt_rect = txt.get_rect(center=(cx, cy))\n",
    "        stone_surf.blit(txt, txt_rect)\n",
    "        \n",
    "        surface.blit(stone_surf, (x - cx, y - cy))\n",
    "\n",
    "    def handle_events(self):\n",
    "        for event in pygame.event.get():\n",
    "            if event.type == pygame.QUIT:\n",
    "                self.exit_game()\n",
    "                \n",
    "            if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:\n",
    "                self.exit_game()\n",
    "            \n",
    "            if self.app_state == \"MENU\":\n",
    "                self.row_input.handle_event(event)\n",
    "                self.col_input.handle_event(event)\n",
    "                for btn in self.menu_buttons:\n",
    "                    btn.handle_event(event)\n",
    "                    \n",
    "            elif self.app_state == \"GAME\":\n",
    "                for btn in self.game_buttons:\n",
    "                    btn.handle_event(event)\n",
    "                    \n",
    "                if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:\n",
    "                    if self.game_state in [\"WAITING_FOR_NULL\", \"PLAYING\"]:\n",
    "                        self.handle_grid_click(event.pos)\n",
    "\n",
    "    def handle_grid_click(self, pos):\n",
    "        # Calculate grid bounds dynamically\n",
    "        grid_area_size = 500\n",
    "        cell_size = min(grid_area_size // self.cols, grid_area_size // self.rows)\n",
    "        offset_x = (self.WIDTH - self.cols * cell_size) // 2\n",
    "        offset_y = 120 + (grid_area_size - self.rows * cell_size) // 2\n",
    "\n",
    "        x, y = pos\n",
    "        if offset_x <= x < offset_x + self.cols * cell_size and offset_y <= y < offset_y + self.rows * cell_size:\n",
    "            c = (x - offset_x) // cell_size\n",
    "            r = (y - offset_y) // cell_size\n",
    "\n",
    "            if (r, c) in self.valid_moves:\n",
    "                val_to_place = self.valid_moves[(r, c)]\n",
    "                \n",
    "                if self.game_state == \"WAITING_FOR_NULL\":\n",
    "                    self.board[r][c] = -1\n",
    "                    self.max_k = 1\n",
    "                    self.game_state = \"PLAYING\"\n",
    "                else:\n",
    "                    self.board[r][c] = val_to_place\n",
    "                    self.max_k = max(self.max_k, val_to_place)\n",
    "                \n",
    "                self.valid_moves = self.get_valid_moves()\n",
    "                if not self.valid_moves:\n",
    "                    self.game_state = \"GAME_OVER\"\n",
    "\n",
    "    def draw_menu(self):\n",
    "        self.screen.fill((34, 47, 62)) # Slightly darker background for menu\n",
    "        \n",
    "        # Title\n",
    "        title = self.title_font.render(\"DENOMINATION\", True, (236, 240, 241))\n",
    "        self.screen.blit(title, title.get_rect(center=(self.WIDTH//2, 150)))\n",
    "        \n",
    "        subtitle = self.subtitle_font.render(\"Grid Setup\", True, (189, 195, 199))\n",
    "        self.screen.blit(subtitle, subtitle.get_rect(center=(self.WIDTH//2, 220)))\n",
    "\n",
    "        # Inputs\n",
    "        lbl_m = self.subtitle_font.render(\"Rows (m):\", True, (255, 255, 255))\n",
    "        self.screen.blit(lbl_m, (280, 310))\n",
    "        self.row_input.draw(self.screen)\n",
    "\n",
    "        lbl_n = self.subtitle_font.render(\"Cols (n):\", True, (255, 255, 255))\n",
    "        self.screen.blit(lbl_n, (280, 390))\n",
    "        self.col_input.draw(self.screen)\n",
    "\n",
    "        # Buttons\n",
    "        for btn in self.menu_buttons:\n",
    "            btn.draw(self.screen, self.btn_font)\n",
    "\n",
    "    def draw_game(self):\n",
    "        self.screen.fill((44, 62, 80)) # Dark slate background\n",
    "\n",
    "        # Draw UI Texts\n",
    "        title = self.title_font.render(\"DENOMINATION\", True, (236, 240, 241))\n",
    "        self.screen.blit(title, title.get_rect(center=(self.WIDTH//2, 40)))\n",
    "\n",
    "        max_txt = self.info_font.render(f\"Current Max (k): {self.max_k}\", True, (241, 196, 15))\n",
    "        self.screen.blit(max_txt, (50, 90))\n",
    "\n",
    "        # Dynamic best text from solver\n",
    "        best_val = self.solver_thread.best_max if self.solver_thread else 0\n",
    "        search_status = \"(Searching...)\" if (self.solver_thread and self.solver_thread.searching) else \"(Search Complete)\"\n",
    "        best_txt = self.info_font.render(f\"Optimal Value {search_status}: {best_val}\", True, (46, 204, 113))\n",
    "        self.screen.blit(best_txt, (self.WIDTH - best_txt.get_width() - 50, 90))\n",
    "\n",
    "        if self.game_state == \"GAME_OVER\":\n",
    "            go_txt = self.title_font.render(f\"Game Over! Final Score: {self.max_k}\", True, (231, 76, 60))\n",
    "            self.screen.blit(go_txt, go_txt.get_rect(center=(self.WIDTH//2, 660)))\n",
    "        elif self.game_state == \"WAITING_FOR_NULL\":\n",
    "            msg = self.info_font.render(\"Click anywhere to place the Null stone\", True, (189, 195, 199))\n",
    "            self.screen.blit(msg, msg.get_rect(center=(self.WIDTH//2, 660)))\n",
    "\n",
    "        # Draw Grid\n",
    "        grid_area_size = 500\n",
    "        cell_size = min(grid_area_size // self.cols, grid_area_size // self.rows)\n",
    "        offset_x = (self.WIDTH - self.cols * cell_size) // 2\n",
    "        offset_y = 120 + (grid_area_size - self.rows * cell_size) // 2\n",
    "\n",
    "        # Draw cells\n",
    "        for r in range(self.rows):\n",
    "            for c in range(self.cols):\n",
    "                cx = offset_x + c * cell_size\n",
    "                cy = offset_y + r * cell_size\n",
    "                rect = pygame.Rect(cx, cy, cell_size, cell_size)\n",
    "                \n",
    "                # Draw cell background and border\n",
    "                pygame.draw.rect(self.screen, (52, 73, 94), rect, border_radius=4)\n",
    "                pygame.draw.rect(self.screen, (127, 140, 141), rect, 2, border_radius=4)\n",
    "\n",
    "                val = self.board[r][c]\n",
    "                center = (cx + cell_size//2, cy + cell_size//2)\n",
    "                \n",
    "                # Dynamic stone size based on grid sizing\n",
    "                radius = int(cell_size // 2 * 0.8)\n",
    "\n",
    "                if val != 0:\n",
    "                    color = self.get_stone_color(val)\n",
    "                    disp_val = \"1\" if val == -1 else str(val)\n",
    "                    self.draw_polished_stone(self.screen, center, radius, color, disp_val)\n",
    "                    \n",
    "                elif (r, c) in self.valid_moves:\n",
    "                    hint_val = self.valid_moves[(r, c)]\n",
    "                    color = self.get_stone_color(hint_val)\n",
    "                    # Draw with alpha 90 for faint look\n",
    "                    self.draw_polished_stone(self.screen, center, radius, color, str(hint_val), alpha=90)\n",
    "\n",
    "        # Draw buttons\n",
    "        for btn in self.game_buttons:\n",
    "            btn.draw(self.screen, self.btn_font)\n",
    "\n",
    "    def draw(self):\n",
    "        if self.app_state == \"MENU\":\n",
    "            self.draw_menu()\n",
    "        else:\n",
    "            self.draw_game()\n",
    "        pygame.display.flip()\n",
    "\n",
    "    def run(self):\n",
    "        while True:\n",
    "            self.handle_events()\n",
    "            self.draw()\n",
    "            self.clock.tick(60)\n",
    "\n",
    "if __name__ == \"__main__\":\n",
